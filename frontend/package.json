{
  "name": "sqs-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Angular-Frontend fuer das pet-basierte SQS Productivity MVP",
  "scripts": {
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "build:development": "ng build --configuration development",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint \"src/**/*.ts\" \"testing/**/*.ts\" \"playwright.config.ts\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss,html}\" \"../tests/**/*.{ts,md}\"",
    "format": "prettier --write \"src/**/*.{ts,scss,html}\" \"../tests/**/*.{ts,md}\""
  },
  "dependencies": {
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/router": "21.2.9",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@angular-devkit/build-angular": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "^4.0.3",
    "eslint": "^9.38.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.6.2",
    "playwright": "^1.56.1",
    "typescript": "5.9.3",
    "vitest": "^4.0.3"
  }
}
