{
  "name": "sqs-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Angular-Frontend für das pet-basierte SQS Productivity MVP",
  "scripts": {
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "build:development": "ng build --configuration development",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node ./scripts/run-e2e.cjs",
    "security:audit": "npm audit --audit-level=moderate --omit=optional",
    "security:lockfile": "vitest run ../tests/unit/frontend/npm-security.test.ts",
    "security:frontend": "npm run security:lockfile && npm run security:audit",
    "lint": "eslint \"src/**/*.ts\" \"testing/**/*.ts\" \"playwright.config.ts\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss,html}\" \"../tests/**/*.ts\" \"../tests/**/*.md\"",
    "format": "prettier --write \"src/**/*.{ts,scss,html}\" \"../tests/**/*.ts\" \"../tests/**/*.md\""
  },
  "dependencies": {
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/platform-browser": "21.2.17",
    "@angular/router": "21.2.17",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.15",
    "@angular/cli": "21.2.15",
    "@angular/compiler-cli": "21.2.17",
    "@playwright/test": "^1.56.1",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.0.3",
    "eslint": "^9.38.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "esbuild-wasm": "0.28.1",
    "vite": "7.3.5",
    "webpack-dev-server": "5.2.4",
    "uuid": "11.1.1"
  }
}
