# ---------------------------------------------------------------------------
# PokeHabit / SQS Semesterarbeit
# Keep source, documentation, lockfiles, migrations, Dockerfiles and wrapper
# scripts in Git. Ignore local dependencies, build output, reports and secrets.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Operating system noise
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Editors and IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
.factorypath
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# Temporary editor files
*.swp
*.swo
*~
\#*\#
.\#*

# ---------------------------------------------------------------------------
# Local secrets and environment files
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.local

# ---------------------------------------------------------------------------
# Java / Maven / Spring Boot
# ---------------------------------------------------------------------------
*.class
target/
backend/target/

pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Keep backend/mvnw, backend/mvnw.cmd and wrapper properties tracked.
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# JVM crash logs
hs_err_pid*
replay_pid*

# ---------------------------------------------------------------------------
# Node / Angular / TypeScript
# ---------------------------------------------------------------------------
node_modules/
frontend/node_modules/
db/node_modules/

.angular/
frontend/.angular/
.tmp/
frontend/.tmp/
.vite/
.pnp
.pnp.js

dist/
frontend/dist/
build/
out/
.next/

*.tsbuildinfo

# Keep package-lock.json files tracked.
!package-lock.json
!frontend/package-lock.json
!db/package-lock.json

# ---------------------------------------------------------------------------
# Tests, coverage and reports
# ---------------------------------------------------------------------------
coverage/
frontend/coverage/
.nyc_output/
playwright-report/
frontend/playwright-report/
test-results/
frontend/test-results/

surefire-reports/
failsafe-reports/
jacoco.exec

quality-output/
quality_output/
quality/reports/

# ---------------------------------------------------------------------------
# Documentation build output
# ---------------------------------------------------------------------------
site/
docs/site/

# Python tooling for docs
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Database and Prisma local artifacts
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
prisma/dev.db
db/prisma/dev.db

# Keep schema, seeds and migrations tracked.
!db/prisma/schema.prisma
!db/prisma/seed.ts
!db/prisma/migrations/
!db/prisma/migrations/**

# ---------------------------------------------------------------------------
# Logs and runtime output
# ---------------------------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Docker and local compose overrides
# ---------------------------------------------------------------------------
docker-compose.override.yml
compose.override.yml

# ---------------------------------------------------------------------------
# Analysis tools
# ---------------------------------------------------------------------------
.sonar/
.scannerwork/

# ---------------------------------------------------------------------------
# Archives and generated packages
# ---------------------------------------------------------------------------
*.jar
*.war
*.nar
*.ear
*.zip
*.tar
*.tar.gz
*.tgz
*.rar

# ---------------------------------------------------------------------------
# Gradle, in case the backend is migrated later
# ---------------------------------------------------------------------------
.gradle/
gradle-app.setting
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ---------------------------------------------------------------------------
# Generated GitHub automation scratch data
# ---------------------------------------------------------------------------
.github/java-upgrade/
.github/modernize/
start.md
sqsagent.md
SQS_v2_tech.pptx
SQS_v2_rettung.pptx
SQS_praesi_1_0.pptx
~$*.pptx

# ---------------------------------------------------------------------------
# Local presentation drafts and generated presentation scripts
# ---------------------------------------------------------------------------
SQS_praesi*.pptx
SQS_presentation*.pptx
scripts/rebuild_sqs_presentation*.ps1
scripts/rebuild_sqs_project_presentation*

# ---------------------------------------------------------------------------
# Local CI / coverage workflow experiments
# ---------------------------------------------------------------------------
.github/workflows/ci.yml
scripts/rebuild_sqs_presentation_1_0.ps1
scripts/rebuild_sqs_presentation_1_0.ps1
scripts/rebuild_sqs_presentation_1_0.ps1
